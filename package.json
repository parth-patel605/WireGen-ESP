{
  "name": "iot-project-builder",
  "private": true,
  "version": "1.0.0",
  "type": "module",
  "main": "electron/main.cjs",
  "overrides": {
    "yauzl": "^3.3.1"
  },
  "scripts": {
    "dev": "vite",
    "build": "tsc -b && vite build",
    "preview": "vite preview",
    "clean": "node scripts/clean.cjs",
    "dev:electron": "concurrently \"vite\" \"wait-on http://localhost:5173 && electron . --dev\"",
    "build:exe": "npm run clean && npm run build && electron-builder"
  },
  "dependencies": {
    "@google/generative-ai": "^0.24.1",
    "react": "^19.1.0",
    "react-dom": "^19.1.0",
    "react-router-dom": "^7.6.2"
  },
  "devDependencies": {
    "@tailwindcss/vite": "^4.1.8",
    "@types/node": "^25.9.3",
    "@types/react": "^19.1.6",
    "@types/react-dom": "^19.1.6",
    "@vitejs/plugin-react": "^4.5.2",
    "concurrently": "^10.0.3",
    "electron": "^42.4.1",
    "electron-builder": "^26.15.3",
    "electron-packager": "^17.1.2",
    "jimp": "^1.6.1",
    "png-to-ico": "^3.0.1",
    "tailwindcss": "^4.1.8",
    "typescript": "~5.8.3",
    "vite": "^6.3.5",
    "wait-on": "^9.0.10"
  },
  "build": {
    "appId": "com.wiregen.ai",
    "productName": "WireGen AI",
    "directories": {
      "output": "release"
    },
    "beforeBuild": "./scripts/beforeBuild.cjs",
    "win": {
      "icon": "public/icon.ico",
      "target": [
        "nsis"
      ],
      "signtoolOptions": {
        "sign": "./scripts/noopSign.cjs"
      }
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true,
      "createDesktopShortcut": true,
      "createStartMenuShortcut": true,
      "shortcutName": "WireGen AI"
    },
    "files": [
      "dist/**/*",
      "electron/**/*",
      "package.json"
    ]
  }
}
